{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores user profile information and fitness goals",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "name": { "type": "string", "description": "The user's display name" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "avatarUrl": { "type": "string", "description": "The URL of the user's avatar" },
        "height": { "type": "number", "description": "The user's height in cm" },
        "currentWeight": { "type": "number", "description": "The user's current weight in kg" },
        "targetWeight": { "type": "number", "description": "The user's target weight in kg" },
        "stepGoal": { "type": "number", "description": "The user's daily step goal" },
        "maxPullUps": { "type": "number", "description": "The user's maximum pull-up count" },
        "oneRMWeighted": { "type": "number", "description": "The user's 1RM for weighted pull-ups in kg" },
        "shortTermGoal": { "type": "string", "description": "The user's short-term goal" },
        "longTermGoal": { "type": "string", "description": "The user's long-term goal" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role in the application" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Workout": {
      "title": "Workout",
      "description": "Stores a single workout session",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who performed the workout" },
        "name": { "type": "string", "description": "The name of the workout" },
        "date": { "type": "string", "format": "date-time", "description": "The date and time of the workout" },
        "exercises": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "name": { "type": "string" },
              "sets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "reps": { "type": "number" },
                    "weight": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["uid", "name", "date", "exercises"]
    },
    "WeeklyPlan": {
      "title": "WeeklyPlan",
      "description": "Stores the user's weekly workout plan",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who owns the plan" },
        "plan": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "string" },
              "type": { "type": "string" },
              "exercises": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "number" },
                    "name": { "type": "string" },
                    "details": { "type": "string" },
                    "completed": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["uid", "plan"]
    },
    "Quote": {
      "title": "Quote",
      "description": "Stores a wise quote",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The text of the quote" },
        "author": { "type": "string", "description": "The author of the quote" },
        "source": { "type": "string", "description": "The source or tradition of the quote" },
        "randomId": { "type": "number", "description": "A random number for efficient random fetching" },
        "category": { "type": "string", "enum": ["fitness", "wisdom", "stoic", "jewish", "psychology", "finance", "balkan", "chinese", "japanese", "daily"], "description": "The category of the quote" }
      },
      "required": ["text", "author", "source", "randomId"]
    },
    "DailyQuote": {
      "title": "DailyQuote",
      "description": "Scraped daily quote cached in Firestore",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "author": { "type": "string" },
        "source": { "type": "string" },
        "fetchDate": { "type": "string", "description": "The date the quote was fetched (YYYY-MM-DD)" },
        "randomId": { "type": "number" },
        "category": { "type": "string", "enum": ["daily"] }
      },
      "required": ["text", "author", "fetchDate"]
    },
    "DailyDigestQuote": {
      "title": "DailyDigestQuote",
      "description": "Scraped daily digest quote stored in Firestore with optional likes tracking",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "author": { "type": "string" },
        "source": { "type": "string" },
        "fetchDate": { "type": "string", "description": "The date the quote was fetched (YYYY-MM-DD)" },
        "order": { "type": "number", "description": "Display order of the quote in the digest" },
        "createdAt": { "type": "string", "description": "Creation timestamp" },
        "likes": { "type": "array", "items": { "type": "string" }, "description": "UIDs of users who liked this quote" },
        "likesCount": { "type": "number", "description": "Total count of likes" }
      },
      "required": ["text", "author", "fetchDate", "order"]
    },
    "QuizQuestion": {
      "title": "QuizQuestion",
      "description": "A wisdom training question",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number" },
        "category": { "type": "string", "enum": ["latin", "jewish", "history", "psychology"] },
        "wisdom": { "type": "string" }
      },
      "required": ["question", "options", "correctAnswer", "category", "wisdom"]
    },
    "Article": {
      "title": "Article",
      "description": "Stores a long-form article or insight (Max 30,000 chars / 5,000 words)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "isAI": { "type": "boolean" }
      },
      "required": ["id", "userId", "title", "content", "date"]
    },
    "PsychologyInsight": {
      "title": "PsychologyInsight",
      "description": "Stores a specialized psychology insight with parallels",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "author": { "type": "string" },
        "source": { "type": "string" },
        "shortExplanation": { "type": "string" },
        "stoicParallel": { "type": "string" },
        "jewishParallel": { "type": "string" },
        "randomId": { "type": "number" },
        "category": { "type": "string", "enum": ["psychology"] }
      },
      "required": ["text", "author", "source", "randomId", "category"]
    },
    "PublicProfile": {
      "title": "PublicProfile",
      "description": "Public user biography and avatar safely isolated from private data with psychology indicators",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "biography": { "type": "string", "description": "Long form human biography" },
        "coverUrl": { "type": "string", "description": "Cover background banner image" },
        "relationshipIntent": { "type": "string", "description": "Target relationship intent" },
        "location": { "type": "string", "description": "Physical user metropolitan area" },
        "height": { "type": "string", "description": "User height in cm" },
        "intellectualInterests": { "type": "array", "items": { "type": "string" }, "description": "Scholarly intellectual dimensions of interest" },
        "fitnessStyle": { "type": "string", "description": "Dominant calisthenic, yoga, or biological recovery profile style" },
        "morningEnergy": { "type": "string", "description": "Sleep recovery chronotype" },
        "mbti": { "type": "string" },
        "mbtiName": { "type": "string" },
        "bigFive": {
          "type": "object",
          "properties": {
            "openness": { "type": "number" },
            "conscientiousness": { "type": "number" },
            "extraversion": { "type": "number" },
            "agreeableness": { "type": "number" },
            "neuroticism": { "type": "number" }
          }
        },
        "mmpiResilience": { "type": "number" },
        "mmpiTruthScore": { "type": "number" },
        "mmpiStatus": { "type": "string" },
        "quizTakenAt": { "type": "string" },
        "updatedAt": { "type": "string", "description": "Server timestamp of update" }
      },
      "required": ["uid", "name"]
    },
    "CommunityPost": {
      "title": "CommunityPost",
      "description": "A public post in the community feed that requires Petar's approval",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "content": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["none", "image", "video", "youtube", "tiktok", "pdf", "word", "sheet"] },
        "mediaUrl": { "type": "string" },
        "mediaName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string" },
        "likes": { "type": "array", "items": { "type": "string" }, "description": "UIDs of users who liked this post" }
      },
      "required": ["id", "userId", "content", "status", "createdAt"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A direct message exchange thread between exactly two users",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Usually sorted_uid1_uid2 for secure matching" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantNames": { "type": "array", "items": { "type": "string" } },
        "participantAvatars": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string" }
      },
      "required": ["id", "participants", "participantNames"]
    },
    "Message": {
      "title": "Message",
      "description": "A direct message within a conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "seen": { "type": "boolean" }
      },
      "required": ["id", "conversationId", "senderId", "senderName", "text", "createdAt"]
    },
    "ArticleComment": {
      "title": "ArticleComment",
      "description": "A user or guest comment on a long-form article/log entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "articleId": { "type": "string" },
        "userId": { "type": ["string", "null"] },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["id", "articleId", "userName", "content", "createdAt", "status"]
    },
    "PostComment": {
      "title": "PostComment",
      "description": "A user or guest comment on a community post in the Scholar feed",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "userId": { "type": ["string", "null"] },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["id", "postId", "userName", "content", "createdAt", "status"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Stores manual paywall activation support tickets",
      "type": "object",
      "properties": {
        "appEmail": { "type": "string", "format": "email" },
        "paypalEmail": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "tier": { "type": "string", "enum": ["monthly", "lifetime"] },
        "status": { "type": "string", "enum": ["pending", "resolved", "rejected"] },
        "createdAt": { "type": "string" },
        "source": { "type": "string" }
      },
      "required": ["appEmail", "paypalEmail", "status", "createdAt"]
    },
    "PreAuthorizedEmail": {
      "title": "PreAuthorizedEmail",
      "description": "Pre-authorized subscription emails",
      "type": "object",
      "properties": {
        "active": { "type": "boolean" },
        "tier": { "type": "string", "enum": ["monthly", "lifetime"] }
      },
      "required": ["active", "tier"]
    }
  },
  "firestore": {
    "/support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Manual activation support tickets"
    },
    "/pre_authorized_emails/{email}": {
      "schema": "PreAuthorizedEmail",
      "description": "Pre-authorized emails database"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile collection"
    },
    "/public_profiles/{userId}": {
      "schema": "PublicProfile",
      "description": "Isolated public profiles and bios"
    },
    "/social_posts/{postId}": {
      "schema": "CommunityPost",
      "description": "Community posts with approval lifecycle"
    },
    "/social_posts/{postId}/comments/{commentId}": {
      "schema": "PostComment",
      "description": "Comments left on community feed posts"
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Direct message head nodes"
    },
    "/conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages subcollection"
    },
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Long-form articles and insights collection"
    },
    "/articles/{articleId}/comments/{commentId}": {
      "schema": "ArticleComment",
      "description": "Comments left on articles/log entries"
    },
    "/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Workout history collection"
    },
    "/plans/{planId}": {
      "schema": "WeeklyPlan",
      "description": "Weekly plan collection"
    },
    "/quotes/{quoteId}": {
      "schema": "Quote",
      "description": "Wise quotes collection"
    },
    "/psychology_insights/{insightId}": {
      "schema": "PsychologyInsight",
      "description": "Collection of the 100 psychology insights"
    },
    "/questions/{questionId}": {
      "schema": "QuizQuestion",
      "description": "Wisdom quiz questions"
    },
    "/daily_quotes_cache/{quoteId}": {
      "schema": "DailyQuote",
      "description": "Cache of daily quotes scraped from wisefitorg.com"
    },
    "/daily_digest_quotes/{quoteId}": {
      "schema": "DailyDigestQuote",
      "description": "Durable daily digest quotes for the sanctuary digest feed"
    }
  }
}
